{
  "name": "wire-grid-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "build:examples": "pnpm -r --filter './examples/*' build",
    "changeset": "changeset",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "dev:next": "pnpm --filter next-basic dev",
    "lint": "oxlint .",
    "release": "pnpm build && changeset publish",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "typecheck:examples": "pnpm -r --filter './examples/*' typecheck",
    "version": "changeset version",
    "check": "pnpm lint && pnpm typecheck && pnpm typecheck:examples && pnpm test && pnpm build && pnpm build:examples && pnpm docs:build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^25.0.1",
    "oxlint": "^1.30.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.3",
    "vitepress": "^1.6.4",
    "vitest": "^4.0.15"
  }
}
